  <script>
    (function(){
      /* mobile sidebar toggle */
      var btn = document.getElementById('sidebar-btn');
      var sidebar = document.getElementById('docs-sidebar');
      var backdrop = document.getElementById('sidebar-backdrop');
      function setSidebar(open) {
        document.body.classList.toggle('sidebar-open', open);
        if (btn) btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      }
      if (btn) {
        btn.addEventListener('click', function(){
          setSidebar(!document.body.classList.contains('sidebar-open'));
        });
      }
      if (backdrop) {
        backdrop.addEventListener('click', function(){ setSidebar(false); });
      }
      if (sidebar) {
        sidebar.addEventListener('click', function(e){
          if (e.target.closest('a')) setSidebar(false);
        });
      }

      /* platform-aware kbd hint */
      var mod = document.getElementById('kbd-mod');
      if (mod) mod.textContent = navigator.platform.indexOf('Mac') > -1 ? '⌘' : 'Ctrl';

      /* escape blurs the search input */
      var query = document.getElementById('query');
      if (query) {
        query.addEventListener('keydown', function(e){
          if (e.key === 'Escape') query.blur();
        });
      }

      /* copy page as markdown */
      var copyBtn = document.getElementById('copy-md-btn');
      if (copyBtn) {
        var copyIco = copyBtn.querySelector('.copy-ico');
        var checkIco = copyBtn.querySelector('.check-ico');
        var label = document.getElementById('copy-md-label');
        copyBtn.addEventListener('click', function(){
          fetch(window.location.pathname + '?format=md', { headers: { 'Accept': 'text/markdown' } })
            .then(function(r){ return r.text(); })
            .then(function(t){
              navigator.clipboard.writeText(t);
              copyIco.classList.add('hidden');
              checkIco.classList.remove('hidden');
              label.textContent = 'Copied!';
              setTimeout(function(){
                copyIco.classList.remove('hidden');
                checkIco.classList.add('hidden');
                label.textContent = 'Copy for LLM';
              }, 2000);
            });
        });
      }

      /* tab groups (shortcode markup carries inert Alpine attributes;
         tabs are wired here by DOM order instead) */
      Array.prototype.forEach.call(document.querySelectorAll('.tab-group'), function(group){
        var panels = Array.prototype.filter.call(group.children, function(el){
          return el.classList && el.classList.contains('tab-panel');
        });
        if (!panels.length) return;
        var buttons = group.querySelectorAll(':scope > .tab-nav .tab-link');
        var select = group.querySelector(':scope > .tab-select select');
        function activate(idx){
          panels.forEach(function(p, i){ p.classList.toggle('tab-panel-active', i === idx); });
          Array.prototype.forEach.call(buttons, function(b, i){ b.classList.toggle('tab-link-active', i === idx); });
          if (select) select.selectedIndex = idx;
        }
        Array.prototype.forEach.call(buttons, function(b, i){
          b.addEventListener('click', function(){ activate(i); });
        });
        if (select) {
          select.addEventListener('change', function(){ activate(select.selectedIndex); });
        }
        group.classList.add('tabs-ready');
        activate(0);
      });
    })();
  </script>
