  <!-- Navigation -->
  <nav class="nav docs-nav" aria-label="Main navigation">
    <div class="nav-inner">
      <div class="nav-left">
        <button class="menu-btn" id="sidebar-btn" aria-expanded="false" aria-controls="docs-sidebar" aria-label="Toggle navigation menu">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path class="ico-menu" stroke-linecap="round" stroke-width="2.5" d="M4 6h16M4 12h16M4 18h16"/>
            <path class="ico-close" stroke-linecap="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
        <a href="/" class="nav-brand" aria-label="Trifle Docs Home">
          <svg aria-hidden="true"><use href="#trifle-logo"/></svg>
          <span>Trifle</span>
          <span class="brand-chip">Docs</span>
        </a>
      </div>

      <form action="<%= search_action %>" method="get" class="nav-search" role="search" aria-label="Search documentation">
        <div class="search-box">
          <label for="scope" class="hidden">Scope</label>
          <select id="scope" name="scope">
            <option value="">All docs</option>
            <% sitemap.sort_by { |(_key, option)| option.dig('_meta', 'nav_order') || 0 }.each do |(key, option)| %>
              <% next if key == '_meta' %>
              <% next unless option.dig('_meta', 'url') %>
              <% scope_value = option.dig('_meta', 'url').sub(%r{^/}, '') %>
              <option value="<%= scope_value %>" <%= params['scope'] == scope_value ? 'selected' : '' %>><%= option.dig('_meta', 'title') %></option>
            <% end %>
          </select>
          <div class="search-divider" aria-hidden="true"></div>
          <label for="query" class="hidden">Search query</label>
          <input
            id="query"
            type="text"
            name="query"
            value="<%= params['query'] %>"
            placeholder="Search docs..."
          >
          <kbd class="search-kbd" aria-hidden="true">
            <span id="kbd-mod">⌘</span><span>K</span>
          </kbd>
          <button type="submit" class="search-btn">
            Search
          </button>
        </div>
      </form>

      <div class="nav-links">
        <a href="https://trifle.io/blog">Blog</a>
        <a href="https://app.trifle.io">App</a>
        <a href="https://github.com/trifle-io">GitHub</a>
      </div>
    </div>
  </nav>

  <!-- Mobile sidebar backdrop -->
  <div class="sidebar-backdrop" id="sidebar-backdrop" aria-hidden="true"></div>

  <div class="docs-layout">
    <aside class="docs-sidebar" id="docs-sidebar">
      <div class="docs-sidebar-inner">
        <nav class="side-nav" aria-label="Documentation navigation">
          <ul>
            <li>
              <a href="/" class="side-link<%= current_path == '/' ? ' active' : '' %>">
                <svg xmlns="http://www.w3.org/2000/svg" class="side-ico" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819" />
                </svg>
                <span>Home</span>
              </a>
            </li>

            <% sitemap.sort_by { |(_key, option)| option.dig('_meta', 'nav_order') || 0 }.each do |(section_key, section)| %>
              <% next if section_key == '_meta' %>
              <% section_url = section.dig('_meta', 'url') %>
              <% next unless section_url %>
              <% section_active = current_path.start_with?(section_url) %>
              <% section_icon = section.dig('_meta', 'svg') %>
              <% section_lang = section.dig('_meta', 'lang') %>

              <li>
                <a href="<%= section_url %>" class="side-link<%= section_active ? ' active' : '' %>">
                  <% if section_icon && !section_icon.to_s.strip.empty? %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="side-ico" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="<%= section_icon %>" />
                    </svg>
                  <% end %>
                  <span><%= section.dig('_meta', 'title') %></span>
                  <% if section_lang && !section_lang.to_s.strip.empty? %>
                    <svg viewBox="0 0 128 128" class="side-lang" fill="currentColor" aria-hidden="true">
                      <%= section_lang %>
                    </svg>
                  <% end %>
                </a>

                <% if section_active %>
                  <ul class="side-sub">
                    <% section.sort_by { |(_key, child)| child.dig('_meta', 'nav_order') || 0 }.each do |(child_key, child)| %>
                      <% next if child_key == '_meta' %>
                      <% child_url = child.dig('_meta', 'url') %>
                      <% next unless child_url %>
                      <% child_active = current_path == child_url || current_path.start_with?("#{child_url}/") %>

                      <% child_has_children = child.any? { |k, v| k != '_meta' && v.is_a?(Hash) && v.dig('_meta', 'url') } %>
                      <li>
                        <a href="<%= child_url %>" class="side-sublink<%= child_active ? ' active' : '' %>">
                          <% if child_has_children %>
                            <svg xmlns="http://www.w3.org/2000/svg" class="side-chev<%= child_active ? ' rot' : '' %>" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                              <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
                            </svg>
                          <% end %>
                          <span><%= child.dig('_meta', 'title') %></span>
                        </a>

                        <% if child_active %>
                          <ul class="side-sub side-sub--deep">
                            <% child.sort_by { |(_key, grandchild)| grandchild.dig('_meta', 'nav_order') || 0 }.each do |(grandchild_key, grandchild)| %>
                              <% next if grandchild_key == '_meta' %>
                              <% grandchild_url = grandchild.dig('_meta', 'url') %>
                              <% next unless grandchild_url %>
                              <% grandchild_active = current_path == grandchild_url %>
                              <li>
                                <a href="<%= grandchild_url %>" class="side-sublink<%= grandchild_active ? ' active' : '' %>"><%= grandchild.dig('_meta', 'title') %></a>
                              </li>
                            <% end %>
                          </ul>
                        <% end %>
                      </li>
                    <% end %>
                  </ul>
                <% end %>
              </li>
            <% end %>
          </ul>
        </nav>
      </div>
    </aside>

    <main class="docs-main" id="main-content">
      <% if meta&.dig('breadcrumbs') %>
        <div class="crumbs">
          <div class="crumb-trail">
            <% meta['breadcrumbs'].count.times do |i| %>
              <% breadcrumb_page = sitemap.dig(*meta['breadcrumbs'].take(i + 1)) %>
              <% if breadcrumb_page&.dig('_meta', 'url') %>
                <a href="<%= breadcrumb_page.dig('_meta', 'url') %>"><%= breadcrumb_page.dig('_meta', 'title') %></a>
                <% if i + 1 != meta['breadcrumbs'].count %>
                  <span class="sep">/</span>
                <% end %>
              <% end %>
            <% end %>
          </div>
          <% if meta.dig('type') != 'collection' %>
            <div class="crumb-actions">
              <button type="button" class="crumb-btn" id="copy-md-btn">
                <svg class="copy-ico" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9.75a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184" /></svg>
                <svg class="check-ico hidden" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span id="copy-md-label">Copy for LLM</span>
              </button>
              <span class="crumb-sep">|</span>
              <a
                href="<%= meta['url'] %>?format=md"
                target="_blank"
                rel="noopener"
                class="crumb-btn"
              >
                <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>
                <span>View as Markdown</span>
              </a>
            </div>
          <% end %>
        </div>
      <% end %>

      <article class="prose">
        <%= yield %>
      </article>
    </main>

    <aside class="docs-toc">
      <% if meta&.dig('toc') && !meta.dig('toc').to_s.strip.empty? %>
        <div class="docs-toc-inner">
          <nav id="on-this-page" aria-labelledby="on-this-page-title">
            <h2 id="on-this-page-title" class="microlabel">On this page</h2>
            <%= meta.dig('toc') %>
          </nav>
        </div>
      <% end %>
    </aside>
  </div>

  <div class="cut" aria-hidden="true">
    <svg><use href="#ico-scissors"/></svg>
  </div>

