<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <% raw_path = "#{request.script_name}#{request.path_info}" %>
  <% canonical_path = raw_path == '/' ? '/' : raw_path.sub(%r{/+$}, '') %>
  <% canonical_url = "https://docs.trifle.io#{canonical_path}" %>
  <% noindex_page = canonical_path.end_with?('/search') %>
  <title><%= meta&.dig('title') ? "#{meta['title']} | Trifle Docs" : 'Trifle Docs' %></title>
  <meta name="description" content="<%= meta&.dig('description') || 'Documentation for Trifle - time-series metrics library for Ruby, Elixir, and Go.' %>">
  <link rel="canonical" href="<%= canonical_url %>">
  <% if noindex_page %><meta name="robots" content="noindex,follow"><% end %>

  <!-- Favicons -->
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon_dark/apple-touch-icon.png" id="apple-touch-icon">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon_dark/favicon-32x32.png" id="favicon-32">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon_dark/favicon-16x16.png" id="favicon-16">
  <link rel="manifest" href="/favicon_dark/site.webmanifest" id="webmanifest">
  <script>
    (function() {
      function setFavicons(theme) {
        var d = theme === 'dark' ? 'favicon_light' : 'favicon_dark';
        document.getElementById('apple-touch-icon').href = '/' + d + '/apple-touch-icon.png';
        document.getElementById('favicon-32').href = '/' + d + '/favicon-32x32.png';
        document.getElementById('favicon-16').href = '/' + d + '/favicon-16x16.png';
        document.getElementById('webmanifest').href = '/' + d + '/site.webmanifest';
      }
      var mq = window.matchMedia('(prefers-color-scheme: dark)');
      setFavicons(mq.matches ? 'dark' : 'light');
      mq.addEventListener('change', function(e) { setFavicons(e.matches ? 'dark' : 'light'); });
    })();
  </script>

  <!-- Open Graph -->
  <meta property="og:type" content="article">
  <meta property="og:url" content="<%= canonical_url %>">
  <meta property="og:title" content="<%= meta&.dig('title') ? "#{meta['title']} | Trifle Docs" : 'Trifle Docs' %>">
  <meta property="og:description" content="<%= meta&.dig('description') || 'Documentation for Trifle - time-series metrics library for Ruby, Elixir, and Go.' %>">
  <meta property="og:image" content="https://trifle.io/landing.jpg">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= meta&.dig('title') ? "#{meta['title']} | Trifle Docs" : 'Trifle Docs' %>">
  <meta name="twitter:description" content="<%= meta&.dig('description') || 'Documentation for Trifle - time-series metrics library for Ruby, Elixir, and Go.' %>">
  <meta name="twitter:image" content="https://trifle.io/landing.jpg">

  <script>
    document.addEventListener('keydown', function(e) {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        document.getElementById('query').focus();
      }
    });
  </script>

  <meta name="color-scheme" content="light dark">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Archivo:wght@500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/zine.css">
  <style>
    <%= Rouge::Themes::Base16.new.render %>

    /* ============================================================
       Rouge overrides — highlighted code blocks live inside the
       zine .prose pre cutout. The container (border, hard shadow,
       paper background, padding) comes from .prose pre in zine.css;
       token colors are remapped onto the --syn-* variables so both
       light and dark paper stay readable.
       ============================================================ */
    .prose .highlight{background:transparent}
    .prose .highlight,
    .prose .highlight code,
    .prose .highlight pre{color:var(--ink)}
    .prose .highlighter-rouge{margin:0}

    /* comments */
    .prose .highlight .c,.prose .highlight .cd,.prose .highlight .cm,
    .prose .highlight .c1,.prose .highlight .cs,.prose .highlight .cp,
    .prose .highlight .cpf{color:var(--syn-com);font-style:italic}
    /* keywords, constants, classes, modules */
    .prose .highlight .k,.prose .highlight .kc,.prose .highlight .kd,
    .prose .highlight .kn,.prose .highlight .kp,.prose .highlight .kr,
    .prose .highlight .kt,.prose .highlight .kv,
    .prose .highlight .nc,.prose .highlight .no,.prose .highlight .nn{color:var(--syn-const)}
    /* methods, functions, builtins */
    .prose .highlight .nf,.prose .highlight .fm,.prose .highlight .nx,
    .prose .highlight .nb,.prose .highlight .bp{color:var(--syn-meth)}
    /* strings */
    .prose .highlight .s,.prose .highlight .sa,.prose .highlight .sb,
    .prose .highlight .sc,.prose .highlight .sd,.prose .highlight .s2,
    .prose .highlight .sh,.prose .highlight .si,.prose .highlight .sx,
    .prose .highlight .s1,.prose .highlight .sr,.prose .highlight .dl{color:var(--syn-str)}
    /* symbols, attributes, variables */
    .prose .highlight .ss,.prose .highlight .sy,.prose .highlight .na,
    .prose .highlight .nv,.prose .highlight .vc,.prose .highlight .vg,
    .prose .highlight .vi,.prose .highlight .vm{color:var(--syn-sym)}
    /* numbers */
    .prose .highlight .m,.prose .highlight .mb,.prose .highlight .mf,
    .prose .highlight .mh,.prose .highlight .mi,.prose .highlight .il,
    .prose .highlight .mo,.prose .highlight .mx{color:var(--syn-num)}
    /* operators, punctuation, plain names */
    .prose .highlight .o,.prose .highlight .ow,.prose .highlight .p,
    .prose .highlight .pi,.prose .highlight .n,.prose .highlight .w{color:var(--ink-70)}
    /* diff / generic / errors */
    .prose .highlight .gh,.prose .highlight .gu{color:var(--ink);font-weight:700}
    .prose .highlight .gd{color:var(--syn-const)}
    .prose .highlight .gi{color:var(--syn-str)}
    .prose .highlight .err{color:var(--syn-const);background:transparent}

    /* ============================================================
       DOCS — layout, nav search, sidebar tree, TOC
       ============================================================ */
    html{scroll-padding-top:96px}

    /* nav: docs variant carries the search form in the middle */
    .docs-nav .nav-inner{max-width:88rem;flex-wrap:wrap}
    .nav-left{display:flex;align-items:center;gap:.7rem}
    .brand-chip{
      font-family:var(--font-mono);font-size:10px;font-weight:700;
      letter-spacing:.06em;text-transform:uppercase;
      border:1.5px solid var(--border);border-radius:3px;
      background:var(--paper-hi);color:var(--ink);
      padding:2px 7px;transform:rotate(-2deg);
    }
    .docs-nav .menu-btn{display:none}
    @media (max-width:1023px){.docs-nav .menu-btn{display:inline-flex}}
    body.sidebar-open .menu-btn .ico-menu{display:none}
    .menu-btn .ico-close{display:none}
    body.sidebar-open .menu-btn .ico-close{display:block}

    .nav-search{flex:1 1 auto;min-width:0;max-width:36rem}
    @media (max-width:767px){
      .nav-search{order:10;flex-basis:100%;max-width:none}
    }
    .search-box{
      display:flex;align-items:center;
      border:2px solid var(--border);border-radius:3px;
      background:var(--paper-hi);
    }
    .search-box:focus-within{outline:3px solid var(--teal-deep);outline-offset:2px}
    .search-box select{
      appearance:none;-webkit-appearance:none;
      border:none;background:transparent;
      font-family:var(--font-mono);font-size:12px;font-weight:700;
      color:var(--ink-70);
      padding:.5rem .5rem .5rem .7rem;
      max-width:9.5rem;cursor:pointer;
    }
    .search-box select:focus{outline:none}
    .search-divider{width:1px;height:1.25rem;flex:none;background:var(--hairline)}
    .search-box input{
      flex:1;min-width:0;border:none;background:transparent;
      font-family:var(--font-body);font-weight:500;font-size:.92rem;
      color:var(--ink);padding:.5rem .75rem;
    }
    .search-box input:focus{outline:none}
    .search-box input::placeholder{
      font-family:var(--font-mono);font-size:12px;
      color:var(--ink-50);letter-spacing:.03em;
    }
    .search-kbd{
      display:none;align-items:center;gap:2px;
      font-family:var(--font-mono);font-size:10px;font-weight:700;
      border:1.5px solid var(--hairline);border-radius:3px;
      background:var(--paper-lo);color:var(--ink-50);
      padding:.15rem .4rem;margin-right:.45rem;
      pointer-events:none;white-space:nowrap;
    }
    @media (min-width:640px){.search-kbd{display:inline-flex}}
    .search-btn{
      font-family:var(--font-mono);font-size:11px;font-weight:700;
      letter-spacing:.05em;text-transform:uppercase;
      background:var(--teal);color:var(--on-accent);
      border:2px solid var(--border);border-radius:3px;
      padding:.35rem .7rem;margin:.3rem;flex:none;
      box-shadow:2px 2px 0 var(--shadow-ink);cursor:pointer;
      transition:transform .15s ease-out, box-shadow .15s ease-out;
    }
    .search-btn:hover{transform:translate(2px,2px);box-shadow:0 0 0 var(--shadow-ink)}

    /* three-column shell */
    .docs-layout{
      max-width:88rem;margin:0 auto;
      display:flex;gap:2.5rem;
      padding:2.2rem clamp(1.25rem,4vw,2.5rem) 5rem;
    }
    .docs-main{min-width:0;flex:1}
    .docs-main .prose{max-width:none}

    /* sidebar */
    .docs-sidebar{width:18rem;flex:none}
    .docs-sidebar-inner{
      position:sticky;top:96px;
      max-height:calc(100vh - 120px);overflow-y:auto;
      padding-bottom:1rem;
    }
    @media (max-width:1023px){
      .docs-sidebar{
        position:fixed;top:0;left:0;z-index:120;
        height:100%;width:18rem;
        background:var(--paper);
        border-right:2px solid var(--border);
        box-shadow:var(--shadow-l);
        padding:1.4rem 1.25rem;overflow-y:auto;
        transform:translateX(-110%);
        transition:transform .2s ease-out;
      }
      body.sidebar-open .docs-sidebar{transform:translateX(0)}
      .docs-sidebar-inner{position:static;max-height:none;overflow:visible;padding-bottom:0}
    }
    .sidebar-backdrop{
      display:none;position:fixed;inset:0;z-index:110;
      background:rgba(11,18,32,.55);
    }
    body.sidebar-open .sidebar-backdrop{display:block}
    @media (min-width:1024px){body.sidebar-open .sidebar-backdrop{display:none}}

    /* sidebar tree */
    .side-nav ul{list-style:none;margin:0;padding:0}
    .side-nav > ul{display:flex;flex-direction:column;gap:1.05rem}
    .side-link{
      display:flex;align-items:center;gap:.55rem;
      font-family:var(--font-mono);font-size:12px;font-weight:700;
      letter-spacing:.06em;text-transform:uppercase;
      color:var(--ink-70);text-decoration:none;
      padding:.15rem 0;
    }
    .side-link:hover{color:var(--teal-ink)}
    .side-link.active{color:var(--teal-ink)}
    .side-ico{width:16px;height:16px;flex:none}
    .side-lang{margin-left:auto;width:16px;height:16px;flex:none;opacity:.7}
    .side-link:hover .side-lang{opacity:1}
    .side-sub{
      margin:.6rem 0 .2rem .5rem;
      border-left:2px solid var(--hairline);
      display:flex;flex-direction:column;gap:2px;
    }
    .side-sublink{
      display:flex;align-items:center;gap:.35rem;
      font-size:.875rem;font-weight:600;
      color:var(--ink-50);text-decoration:none;
      padding:.3rem .6rem .3rem .8rem;
      margin-left:-2px;               /* chip sits on the rail */
      border-left:2px solid transparent;
      border-radius:0 2px 2px 0;
      transition:color .12s ease-out, background-color .12s ease-out, border-color .12s ease-out;
    }
    .side-sublink:hover{
      color:var(--ink);
      background:var(--hairline-soft);
      border-left-color:var(--teal);
    }
    .side-sublink.active{
      color:var(--teal-ink);font-weight:700;
      background:var(--teal-wash);
      border-left-color:var(--teal);
    }
    /* third level: dashed rail, smaller, quieter */
    .side-sub--deep{
      margin:.3rem 0 .35rem .8rem;
      border-left:2px dashed var(--hairline);
      gap:1px;
    }
    .side-sub--deep .side-sublink{
      font-size:.8rem;font-weight:500;
      padding:.25rem .55rem .25rem .7rem;
    }
    .side-sub--deep .side-sublink.active{font-weight:700}
    .side-chev{width:12px;height:12px;flex:none;margin-left:-.2rem;transition:transform .15s ease-out}
    .side-chev.rot{transform:rotate(90deg)}

    /* breadcrumbs row */
    .crumbs{
      display:flex;align-items:center;justify-content:space-between;gap:1rem;
      margin-bottom:1.6rem;padding-bottom:.9rem;
      border-bottom:2px dashed var(--hairline);
    }
    .crumb-trail{
      display:flex;flex-wrap:wrap;align-items:center;gap:.5rem;
      font-family:var(--font-mono);font-size:11px;font-weight:700;
      letter-spacing:.12em;text-transform:uppercase;
      color:var(--ink-50);
    }
    .crumb-trail a{color:inherit;text-decoration:none}
    .crumb-trail a:hover{color:var(--teal-ink)}
    .crumb-trail .sep{color:var(--ink-30)}
    .crumb-actions{display:none;align-items:center;gap:.5rem;flex:none}
    @media (min-width:640px){.crumb-actions{display:flex}}
    .crumb-sep{color:var(--ink-30)}
    .crumb-btn{
      display:inline-flex;align-items:center;gap:.35rem;
      font-family:var(--font-mono);font-size:10.5px;font-weight:700;
      letter-spacing:.05em;text-transform:uppercase;
      color:var(--ink);text-decoration:none;
      border:1.5px solid var(--border);border-radius:3px;
      background:var(--paper-hi);
      padding:.3rem .6rem;
      box-shadow:2px 2px 0 var(--shadow-ink);cursor:pointer;
      transition:transform .15s ease-out, box-shadow .15s ease-out;
    }
    .crumb-btn:hover{transform:translate(2px,2px);box-shadow:0 0 0 var(--shadow-ink)}
    .crumb-btn svg{width:13px;height:13px;flex:none}
    .crumb-btn .check-ico{color:var(--teal-ink)}

    /* TOC */
    .docs-toc{display:none}
    @media (min-width:1280px){.docs-toc{display:block;width:14rem;flex:none}}
    .docs-toc-inner{position:sticky;top:96px}
    nav#on-this-page ul{list-style:none;padding-left:0;margin:0;font-size:.85rem}
    nav#on-this-page > ul{margin-top:1rem;border-left:2px solid var(--hairline);padding-left:.85rem}
    nav#on-this-page ul ul{padding-left:.85rem}
    nav#on-this-page li{margin-top:.5rem}
    nav#on-this-page a{color:var(--ink-50);font-weight:600;text-decoration:none}
    nav#on-this-page a:hover{color:var(--teal-ink)}

    /* prose-embedded interactive elements — undo .prose a treatment */
    .prose a.btn{font-weight:800;border:2px solid var(--border)}
    .prose a.btn:hover{background:var(--teal);color:var(--on-accent)}
    .prose a.btn--ghost{color:var(--ink)}
    .prose a.btn--ghost:hover{background:var(--paper-hi);color:var(--ink)}

    /* ============================================================
       DOCS COMPONENTS — class names emitted by markdown_shortcodes
       ============================================================ */
    /* callouts — flat wash labels */
    .callout{
      border:2px solid var(--border);border-radius:3px;
      background:var(--paper-hi);
      padding:1rem 1.2rem;margin:1.4rem 0;
      color:var(--ink-70);
    }
    .callout > :last-child{margin-bottom:0}
    .callout-title,
    .prose .callout-title{
      font-family:var(--font-mono);font-size:11px;font-weight:700;
      letter-spacing:.1em;text-transform:uppercase;
      color:var(--ink);margin:0 0 .5rem;
    }
    .callout-note{background:var(--teal-wash)}
    .callout-note .callout-title{color:var(--teal-ink)}
    .callout-warn{background:var(--amber-wash)}
    .callout-warn .callout-title{color:var(--amber-ink)}

    /* doc cards — paper cutouts */
    .doc-card{
      background:var(--paper-hi);
      border:2px solid var(--border);border-radius:3px;
      box-shadow:var(--shadow-s);
      padding:1.1rem 1.3rem;margin:1.4rem 0;
    }
    .doc-card-header{
      display:flex;align-items:flex-start;justify-content:space-between;
      gap:1rem;flex-wrap:wrap;
    }
    .doc-card-title,
    .prose .doc-card-title{
      font-family:var(--font-display);font-weight:400;
      font-size:1.1rem;line-height:1.2;letter-spacing:-.01em;
      color:var(--ink);margin:0;
    }
    .doc-card-meta{
      font-family:var(--font-mono);font-size:11px;font-weight:700;
      letter-spacing:.05em;color:var(--ink-50);margin-top:.3rem;
    }
    .doc-card-body{color:var(--ink-70);margin-top:.6rem}
    .doc-card-body > :last-child{margin-bottom:0}
    .doc-card-link{flex:none}
    .prose .doc-card-link a,
    .doc-card-link a{
      display:inline-flex;align-items:center;
      font-family:var(--font-mono);font-size:10.5px;font-weight:700;
      letter-spacing:.05em;text-transform:uppercase;text-decoration:none;
      color:var(--ink);
      border:1.5px solid var(--border);border-radius:3px;
      background:var(--paper-hi);
      padding:.3rem .6rem;
      box-shadow:2px 2px 0 var(--shadow-ink);
      transition:transform .15s ease-out, box-shadow .15s ease-out;
    }
    .prose .doc-card-link a:hover,
    .doc-card-link a:hover{
      transform:translate(2px,2px);box-shadow:0 0 0 var(--shadow-ink);
      background:var(--paper-hi);color:var(--ink);
    }

    /* tab groups — ink-bordered, press-down tabs */
    .tab-group{
      border:2px solid var(--border);border-radius:3px;
      background:var(--paper-hi);
      overflow:hidden;margin:1.4rem 0;
    }
    .tab-select{
      padding:.75rem;background:var(--paper-lo);
      border-bottom:2px solid var(--border);
      position:relative;
    }
    .tab-select select{
      width:100%;appearance:none;-webkit-appearance:none;
      background:var(--paper-hi);
      border:2px solid var(--border);border-radius:3px;
      padding:.5rem 2.5rem .5rem .75rem;
      font-family:var(--font-mono);font-size:13px;font-weight:700;
      color:var(--ink);cursor:pointer;
    }
    .tab-select svg{
      position:absolute;right:1.5rem;top:50%;
      transform:translateY(-50%);
      width:1rem;height:1rem;color:var(--ink-50);
      pointer-events:none;
    }
    .tab-nav{display:none}
    .tab-panel{padding:1.1rem 1.2rem}
    .tab-panel > :last-child{margin-bottom:0}
    /* JS-driven visibility: before JS runs, all panels stay visible */
    .tab-group.tabs-ready > .tab-panel{display:none}
    .tab-group.tabs-ready > .tab-panel.tab-panel-active{display:block}
    @media (min-width:640px){
      .tab-select{display:none}
      .tab-nav{
        display:block;background:var(--paper-lo);
        border-bottom:2px solid var(--border);
        padding:.65rem .75rem;
      }
      .tab-nav-links{display:flex;flex-wrap:wrap;gap:.5rem}
      .tab-link{
        font-family:var(--font-mono);font-size:11.5px;font-weight:700;
        letter-spacing:.05em;text-transform:uppercase;
        background:var(--paper-hi);color:var(--ink-70);
        border:2px solid var(--border);border-radius:3px;
        padding:.4rem .8rem;
        box-shadow:2px 2px 0 var(--shadow-ink);cursor:pointer;
        transition:transform .15s ease-out, box-shadow .15s ease-out;
      }
      .tab-link:hover{transform:translate(1px,1px);box-shadow:1px 1px 0 var(--shadow-ink)}
      .tab-link-active,
      .tab-link.tab-link-active:hover{
        background:var(--teal);color:var(--on-accent);
        transform:translate(2px,2px);box-shadow:0 0 0 var(--shadow-ink);
      }
    }

    /* method cards / signatures */
    .method-card{
      background:var(--paper-hi);
      border:2px solid var(--border);border-radius:3px;
      padding:1.1rem 1.3rem;margin:1.4rem 0;
    }
    .method-card-title{
      font-family:var(--font-mono);font-size:11px;font-weight:700;
      letter-spacing:.1em;text-transform:uppercase;
      color:var(--ink-50);margin-bottom:.5rem;
    }
    .method-card-signature{margin-bottom:.75rem}
    .method-card-signature code{
      display:block;white-space:pre-wrap;
      font-family:var(--font-mono);font-size:.85rem;
      background:var(--paper-lo);color:var(--ink);
      border:2px solid var(--border);border-radius:3px;
      padding:.6rem .75rem;
    }

    .arg-list{margin:0;padding:0}
    .arg-row{padding:.75rem 0 0;margin-top:.75rem;border-top:1px solid var(--hairline)}
    .arg-row dt{
      margin:0;font-weight:700;color:var(--ink);
      display:flex;flex-wrap:wrap;align-items:center;gap:.4rem;
    }
    .arg-row dd{margin:.4rem 0 0;color:var(--ink-70);font-size:.9rem}
    .arg-row dd p{margin:0}

    /* badges — small flat mono chips */
    .badge{
      display:inline-flex;align-items:center;
      font-family:var(--font-mono);font-size:10.5px;font-weight:700;
      letter-spacing:.04em;
      border:1.5px solid var(--border);border-radius:3px;
      background:var(--paper-lo);color:var(--ink);
      padding:.1rem .45rem;
    }
    .badge-type{background:var(--paper-lo)}
    .badge-required{background:var(--teal-wash)}
    .badge-optional{background:var(--amber-wash)}
    .badge-default{background:var(--violet-wash)}

    /* search results — zine cutout cards */
    .search-head h1{margin-bottom:.6rem}
    .search-meta,
    .prose .search-meta{color:var(--ink-70);margin:0}
    .search-scope{font-family:var(--font-mono);font-weight:700;color:var(--teal-ink)}
    .search-results{margin-top:2rem}
    .search-card{
      background:var(--paper-hi);
      border:2px solid var(--border);border-radius:3px;
      box-shadow:var(--shadow-s);
      padding:1.25rem 1.4rem;margin-bottom:1.5rem;
      transform:rotate(-.4deg);
    }
    .search-card:nth-child(even){transform:rotate(.35deg)}
    .search-card h2{
      font-family:var(--font-display);font-weight:400;
      font-size:1.35rem;line-height:1.2;letter-spacing:-.01em;
      margin:0;
    }
    .prose .search-card h2 a,
    .search-card h2 a{color:var(--teal-ink);text-decoration:none;border-bottom:none}
    .prose .search-card h2 a:hover,
    .search-card h2 a:hover{background:var(--teal-hi);color:var(--on-accent)}
    .search-excerpt,
    .prose .search-excerpt{color:var(--ink-70);margin:.7rem 0 0}
    .search-url{
      font-family:var(--font-mono);font-size:11px;font-weight:700;
      letter-spacing:.05em;color:var(--ink-50);margin-top:.9rem;
    }

    /* blog byline */
    .blog-byline{margin-bottom:2rem}
    .blog-byline .sep{margin:0 .5rem}

    /* 404 */
    .nf-hero{
      display:flex;flex-direction:column;align-items:center;
      text-align:center;padding:clamp(3rem,8vw,6rem) 0;
    }
    .nf-code,
    .prose .nf-code{
      font-family:var(--font-display);font-weight:400;
      font-size:clamp(6rem,14vw,9rem);line-height:1;
      letter-spacing:-.03em;color:var(--ink);
      text-shadow:6px 6px 0 color-mix(in srgb, var(--teal) 40%, transparent);
      margin:0 0 1.6rem;
    }
    .nf-title,
    .prose .nf-title{
      font-family:var(--font-display);font-weight:400;
      font-size:clamp(1.4rem,3vw,1.9rem);line-height:1.15;
      letter-spacing:-.01em;color:var(--ink);
      margin:0 0 .9rem;
    }
    .nf-sub,
    .prose .nf-sub{color:var(--ink-70);max-width:30rem;margin:0 0 1.4rem}
    .nf-note{
      background:var(--teal-wash);
      border:2px solid var(--border);border-radius:3px;
      padding:1rem 1.4rem;max-width:34rem;
      transform:rotate(-.5deg);
      margin-bottom:2.6rem;
    }
    .nf-note p{font-size:.92rem;color:var(--ink);margin:0}
    .nf-note-strong{font-weight:800}
    .nf-ctas{display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:1rem}
  </style>
</head>
<body>
