<section class="search-head">
  <h1>Search Docs</h1>
  <% if query && !query.strip.empty? %>
    <p class="search-meta">
      <%= results.length %> result<%= results.length == 1 ? '' : 's' %> for "<%= query %>"
      <% if scope && !scope.strip.empty? %>
        in <span class="search-scope"><%= scope %></span>
      <% end %>
    </p>
  <% end %>
</section>

<% if results.any? %>
  <section class="search-results">
    <% results.each do |result| %>
      <% result_url = [request.script_name, result[:url]].join('/').gsub(%r{/+}, '/') %>
      <% result_url = "/#{result_url}" unless result_url.start_with?('/') %>
      <article class="search-card">
        <h2>
          <a href="<%= result_url %>"><%= result[:title] %></a>
        </h2>
        <% if result[:excerpt] && !result[:excerpt].strip.empty? %>
          <p class="search-excerpt"><%= result[:excerpt] %></p>
        <% end %>
        <div class="search-url">/<%= result[:url] %></div>
      </article>
    <% end %>
  </section>
<% elsif query && !query.strip.empty? %>
  <p>No documentation pages matched this query.</p>
<% else %>
  <p>Enter a term in the navbar search field to find content.</p>
<% end %>
